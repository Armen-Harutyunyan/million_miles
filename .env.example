# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload / app secrets
PAYLOAD_SECRET=replace-with-a-long-random-string
CRON_SECRET=replace-with-a-separate-long-random-string

# MongoDB
# Local example:
MONGODB_URI=mongodb://127.0.0.1:27017/million_miles
# Atlas example:
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/million_miles?retryWrites=true&w=majority

# ENCAR sync settings
ENCAR_SYNC_PAGES=3
ENCAR_PAGE_SIZE=24
ENCAR_QUERY=(And.Hidden.N._.CarType.N.)
